#!/usr/bin/env sh
# Managed via package.json "prepare" -> git config core.hooksPath .githooks
set -e

echo "▶ pre-commit: lint"
bun run lint

echo "▶ pre-commit: types portability (attw)"
bun run check:exports

echo "▶ pre-commit: changeset status"
env -u GIT_DIR -u GIT_INDEX_FILE -u GIT_WORK_TREE -u GIT_PREFIX bunx @changesets/cli status --since=origin/main
