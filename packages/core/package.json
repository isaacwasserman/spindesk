{
  "name": "@spindesk/core",
  "version": "0.2.0",
  "description": "Embeddable service desk API built on futonic",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isaacwasserman/spindesk.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./drizzle": {
      "import": "./dist/drizzle.js",
      "types": "./dist/drizzle.d.ts"
    }
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check:exports": "bun run build && attw --pack . --profile esm-only",
    "lint": "biome check src/",
    "format": "biome format --write src/"
  },
  "dependencies": {
    "@standard-schema/spec": "1.1.0",
    "better-call": "^2.0.5",
    "futonic": "0.2.0",
    "kysely": "^0.29.3",
    "liqe": "^3.8.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
