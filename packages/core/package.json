{
  "name": "@spindesk/core",
  "version": "0.1.0",
  "description": "Embeddable service desk API built on futonic",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isaacwasserman/spindesk.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./drizzle": {
      "import": "./dist/drizzle.js",
      "types": "./dist/drizzle.d.ts"
    }
  },
  "scripts": {
    "build": "tsup && rollup -c rollup.dts.config.mjs",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check:exports": "bun run build && attw --pack . --profile esm-only",
    "lint": "biome check src/",
    "format": "biome format --write src/"
  },
  "dependencies": {
    "better-call": "^2.0.5",
    "futonic": "0.1.1-canary.a7b3fdb",
    "kysely": "^0.29.3",
    "liqe": "^3.8.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@biomejs/biome": "^1.9.4",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@types/bun": "latest",
    "drizzle-orm": "^0.45.2",
    "rollup": "^4.53.2",
    "rollup-plugin-dts": "^6.1.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.30.0",
    "typescript": "^5"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    }
  },
  "files": ["dist"],
  "license": "MIT"
}
