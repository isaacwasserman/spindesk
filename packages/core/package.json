{
  "name": "@spindesk/core",
  "version": "0.1.0",
  "description": "Embeddable service desk API built on futonic",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isaacwasserman/spindesk.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "format": "biome format --write src/"
  },
  "dependencies": {
    "better-call": "^1.3.7",
    "futonic": "0.1.1-canary.9e309ac",
    "liqe": "^3.8.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "files": ["dist"],
  "license": "MIT"
}
