{
  "name": "spindesk",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isaacwasserman/spindesk.git"
  },
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "dev": "bun run --cwd apps/demo dev",
    "build": "bun run --cwd packages/core build",
    "test": "bun run --filter demo test",
    "typecheck": "bun run --cwd packages/core typecheck",
    "check:exports": "bun run --cwd packages/core check:exports",
    "lint": "bun run --cwd packages/core lint",
    "format": "bun run --cwd packages/core format"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
